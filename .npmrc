# Не піднімати всі пакети в корінь (краща ізоляція, pnpm-стиль)
shamefully-hoist=false

# Дозволяємо деяким інструментам (eslint, postcss) працювати з кореня
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@next/eslint-plugin-next

# Не блокуємо встановлення при конфліктах peer dependencies
strict-peer-dependencies=false

# Автоматично встановлювати peer dependencies
auto-install-peers=true
