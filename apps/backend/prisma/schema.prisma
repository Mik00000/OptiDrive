datasource db {
  provider = "postgresql" // або "mysql" / "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Ролі або дозволи для API-ключів
enum KeyPermission {
  FULL_ACCESS
  READ_ONLY
  UPLOAD_ONLY
}

// Дозволи для кастомних ролей (RBAC)
enum Permission {
  MANAGE_USERS
  MANAGE_ROLES
  MANAGE_BILLING
  UPLOAD_FILES
  DELETE_FILES
  MANAGE_API_KEYS
  VIEW_ANALYTICS
  MANAGE_WORKSPACE
}

// Роль користувача
model Role {
  id          String       @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean      @default(false)
  permissions Permission[]
  
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  members     WorkspaceUser[]
  invitations Invitation[]

  @@unique([name, workspaceId])
}

// Статуси оплати інвойсів
enum InvoiceStatus {
  PAID
  PENDING
  FAILED
}

// Тарифи підписки
enum PlanType {
  FREE
  PRO
  ENTERPRISE
}

enum ActivityType {
  FILE_UPLOADED
  FILE_DELETED
  KEY_GENERATED
  KEY_REVOKED
  PLAN_UPGRADED
  SETTING_CHANGED
  MEMBER_INVITED
  MEMBER_JOINED
  MEMBER_REMOVED
  MEMBER_LEFT
  ROLE_UPDATED
  OWNERSHIP_TRANSFERRED
  WORKSPACE_CREATED
}

// 1. Користувач системи
model User {
  id                     String          @id @default(cuid())
  email                  String          @unique
  passwordHash           String?
  name                   String?
  avatarUrl              String?
  googleId               String?         @unique
  githubId               String?         @unique
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  emailVerified          Boolean         @default(false)
  verificationCode       String?
  verificationCodeExpiry DateTime?
  resetPasswordToken     String?
  resetPasswordExpiry    DateTime?

  // Очікувана зміна email (потребує верифікації)
  pendingEmail           String?
  pendingEmailCode       String?
  pendingEmailCodeExpiry DateTime?

  activeWorkspaceId      String?
  activeWorkspace        Workspace?      @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  workspaces             WorkspaceUser[]

  // Notification Preferences
  emailWeeklySummary  Boolean  @default(true)
  emailQuotaWarnings  Boolean  @default(true)
  emailSecurityAlerts Boolean  @default(true)
  emailBillingAlerts  Boolean  @default(true)

  // Зв'язок із логами дій (якщо користувача видалять, логи залишаються, але поле userId стане null)
  activityLogs ActivityLog[]
}

// 2. Робочий простір (Основний контейнер бізнесу)
model Workspace {
  id             String   @id @default(cuid())
  name           String   // Наприклад, "Acme Corp"
  slug           String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Ліміти та поточне використання в BigInt
  plan                 PlanType @default(FREE)
  storageUsed          BigInt   @default(0)
  bandwidthUsed        BigInt   @default(0)
  monthlyOptimizations Int      @default(0)

  // Налаштування стиснення за замовчуванням
  defaultPreset        String   @default("web_balanced")
  defaultFormat        String   @default("auto")
  defaultQuality       Int      @default(80)
  defaultStripMetadata Boolean  @default(true)
  defaultMaxWidth      Int?
  defaultMaxHeight     Int?
  defaultFit           String   @default("cover")

  // Попередження про ліміти (для запобігання дублювання листів)
  warnedStorage80       Boolean  @default(false)
  warnedStorage100      Boolean  @default(false)
  warnedBandwidth80     Boolean  @default(false)
  warnedBandwidth100    Boolean  @default(false)
  warnedOptimizations80  Boolean  @default(false)
  warnedOptimizations100 Boolean  @default(false)

  // Зв'язки
  members        WorkspaceUser[]
  activeUsers    User[]          @relation("ActiveWorkspace")
  apiKeys        ApiKey[]
  files          MediaFile[]
  folders        Folder[]
  tags           Tag[]
  invoices       Invoice[]
  analyticsLogs  AnalyticsLog[]
  activityLogs   ActivityLog[]
  invitations    Invitation[]
  roles          Role[]
  shareLinks     ShareLink[]
  webhooks       Webhook[]
}

model WorkspaceUser {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, workspaceId])
}

// 3. API Ключі для безпечної інтеграції
model ApiKey {
  id          String        @id @default(cuid())
  name        String        // Наприклад, "Production-Backend"
  tokenHash   String        @unique // Хеш токена для перевірки на бекенді (незворотний)
  maskedToken String        // Рядок типу "op_live_••••••••3x9q" для безпечного виведення в UI
  permissions KeyPermission @default(READ_ONLY)
  createdAt   DateTime      @default(now())
  lastUsedAt  DateTime?
  
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// 4. Папки для організації медіа
model Folder {
  id          String   @id @default(cuid())
  name        String
  color       String?  // Кольорова мітка папки
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?

  parentId    String?
  parent      Folder?  @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderToFolder")

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  files       MediaFile[]
  tags        Tag[]
  shareLinks  ShareLink[]

  @@unique([name, parentId, workspaceId])
}

// 5. Медіатека
model MediaFile {
  id            String   @id @default(cuid())
  name          String   // Наприклад, "hero-banner.png"
  format        String   // Наприклад, "webp"
  originalSize  BigInt   // Розмір у байтах до стиснення
  optimizedSize BigInt   // Розмір у байтах після стиснення
  savings       Float    // Відсоток економії, наприклад, 81.5
  cdnUrl        String   // Згенероване CDN-посилання
  createdAt     DateTime @default(now())
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?

  folderId      String?
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  tags          Tag[]
  shareLinks    ShareLink[]

  @@index([workspaceId])
  @@index([folderId])
}

// 5. Історія платежів та інвойси
model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique // Наприклад, "INV-2023-10-01"
  amount        Float
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  pdfUrl        String?

  workspaceId   String
  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// 6. Логи запитів для високопродуктивних графіків (Часові ряди)
model AnalyticsLog {
  id          String   @id @default(cuid())
  statusCode  Int      // 200, 400 тощо
  bytesSaved  BigInt   // Економія за один конкретний запит
  timestamp   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, timestamp])
}

// 7. Журнал аудиту та дій для компонента RecentActivity
model ActivityLog {
  id          String       @id @default(cuid())
  type        ActivityType
  description String       // Текстовий опис події ("Uploaded hero-banner.png", "Revoked key ...")
  createdAt   DateTime     @default(now())
  
  // Хто саме виконав дію (опціонально, бо дія могла відбутися автоматично через API-ключ)
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// 8. Запрошення до робочого простору
model Invitation {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([email, workspaceId])
  @@index([token])
}

// 9. Теги для файлів та папок
model Tag {
  id          String      @id @default(cuid())
  name        String
  color       String      @default("#3b82f6") // Колір тегу за замовчуванням (HEX)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  files       MediaFile[]
  folders     Folder[]

  @@unique([name, workspaceId])
  @@index([workspaceId])
}

// 10. Публічні посилання
model ShareLink {
  id          String    @id @default(cuid())
  slug        String    @unique
  isFolder    Boolean   @default(false)
  fileId      String?
  folderId    String?
  password    String?
  expiresAt   DateTime?
  downloads   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  file        MediaFile? @relation(fields: [fileId], references: [id], onDelete: Cascade)
  folder      Folder?    @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([workspaceId])
}

// 11. Вебхуки для користувачів
model Webhook {
  id          String   @id @default(cuid())
  name        String
  url         String
  secret      String   // Для підпису payload (HMAC-SHA256)
  isActive    Boolean  @default(true)
  events      String[] // наприклад ["file.optimized"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  deliveries  WebhookDelivery[]

  @@index([workspaceId])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event      String
  status     Int      // HTTP status code (наприклад 200, 500)
  success    Boolean
  payload    String   // JSON payload sent
  response   String?  // Response body if any
  duration   Int      // Response time in ms
  createdAt  DateTime @default(now())

  @@index([webhookId])
}