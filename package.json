{
  "name": "optidrive",
  "version": "1.0.0",
  "description": "OptiDrive — монорепозиторій",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "pnpm --filter @optidrive/frontend dev",
    "dev:backend": "pnpm --filter @optidrive/backend dev",
    "build": "turbo run build",
    "build:shared": "pnpm --filter @optidrive/shared build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@9.0.0"
}
